# Mode-based env files (all committed except .env.local):
#
#   .env.development   → used by `npm run dev`    (points at local uvicorn)
#   .env.vm            → used by `npm run dev:vm` (points at the deployed VM)
#   .env.local         → gitignored; YOUR overrides, always wins unless a
#                         mode-specific file re-sets the same key
#
# Precedence (later wins): .env → .env.local → .env.[mode] → .env.[mode].local
#
# Typical usage:
#   npm run dev         # local backend — start uvicorn in another terminal first
#   npm run dev:vm      # deployed backend — no uvicorn needed locally
#
# Only override VITE_API_TARGET in .env.local if you need a one-off (e.g., a
# colleague's VM or a staging box) — otherwise edit the committed files.

VITE_API_TARGET=http://127.0.0.1:8000
