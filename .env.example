BASEBALL_LOG_LEVEL=INFO

# DuckDB memory cap. Recommended on the 8 GB VM to avoid OOM during big aggregations.
# Leave blank for DuckDB's default (~80% of system RAM).
BASEBALL_DUCKDB_MEMORY_LIMIT=4GB

# Override the data directory. Defaults to ./data/ alongside the repo.
# BASEBALL_DATA_ROOT=/mnt/baseball/data
